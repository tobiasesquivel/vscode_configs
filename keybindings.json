[
  // =========================================================
  // NAVEGACIÓN DE PANELES (SPLITS)
  // =========================================================
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp",
    "when": "editorTextFocus && vim.mode != 'Insert' && !suggestWidgetVisible && !inQuickOpen && !actionWidgetVisible && !menuFocus && !codeActionMenuVisible",
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown",
    "when": "editorTextFocus && vim.mode != 'Insert' && !suggestWidgetVisible && !inQuickOpen && !actionWidgetVisible && !menuFocus && !codeActionMenuVisible",
  },
  // =========================================================
  // NAVEGACIÓN EN QUICK FIX (CODE ACTIONS)
  // =========================================================
  {
    "key": "ctrl+j",
    "command": "selectNextCodeAction",
    "when": "codeActionMenuVisible",
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevCodeAction",
    "when": "codeActionMenuVisible",
  },
  // TODO: Por mas configuraciones, esto no se ejecuta;
  {
    "key": "ctrl+l",
    "command": "acceptSelectedCodeAction",
    "when": "codeActionMenuVisible",
  },
  // =========================================================
  // GESTIÓN DE PESTAÑAS (TABS) Y EDITORES
  // =========================================================
  {
    "key": "ctrl+h",
    "command": "workbench.action.previousEditor",
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.nextEditor",
  },
  {
    "key": "ctrl+w",
    "command": "workbench.action.closeActiveEditor",
    "when": "!editorTextFocus && !vim.active || vim.mode != 'Insert'",
  },

  // =========================================================
  // NAVEGACIÓN EN MENÚS Y LISTAS (CONFLICT RESOLUTION)
  // =========================================================
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetVisible",
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetVisible",
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen",
  },

  // =========================================================
  // EXPLORADOR DE ARCHIVOS Y SIDEBAR
  // =========================================================
  {
    "key": "ctrl+e",
    "command": "workbench.view.explorer",
  },
  {
    "key": "ctrl+e",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "filesExplorerFocus",
  },
  {
    "key": "ctrl+b",
    "command": "workbench.action.toggleSidebarVisibility",
  },
  {
    "key": "ctrl+e",
    "command": "-workbench.action.quickOpen",
  },

  // =========================================================
  // VIM & EDICIÓN DE CÓDIGO
  // =========================================================
  {
    "key": "tab",
    "command": "editor.action.indentLines",
    "when": "editorTextFocus && vim.mode != 'Insert'",
  },
  {
    "key": "shift+tab",
    "command": "editor.action.outdentLines",
    "when": "editorTextFocus && vim.mode != 'Insert'",
  },
  {
    "key": "s",
    "command": "findJump.activate",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space",
    "command": "vspacecode.space",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },

  // =========================================================
  // CHAT & AI (ANTIGRAVITY)
  // =========================================================
  {
    "key": "ctrl+m",
    "command": "workbench.action.chat.newChat",
    "when": "chatIsEnabled && inChat",
  },
  {
    "key": "ctrl+l",
    "command": "-workbench.action.chat.newChat",
    "when": "chatIsEnabled && inChat",
  },
  {
    "key": "ctrl+m",
    "command": "antigravity.prioritized.chat.open",
    "when": "!terminalFocus",
  },
  {
    "key": "ctrl+l",
    "command": "-antigravity.prioritized.chat.open",
    "when": "!terminalFocus",
  },
  {
    "key": "ctrl+m",
    "command": "workbench.action.chat.newChat",
    "when": "!terminalFocus",
  },
  {
    "key": "ctrl+e",
    "command": "-antigravity.switchBetweenWorkspaceAndAgent",
  },

  // =========================================================
  // TERMINAL
  // =========================================================
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.terminal.scrollDown",
    "when": "terminalFocusInAny && terminalHasBeenCreated && !terminalAltBufferActive || terminalFocusInAny && terminalProcessSupported && !terminalAltBufferActive",
  },
  {
    "key": "ctrl+shift+k",
    "command": "workbench.action.terminal.scrollUp",
    "when": "terminalFocusInAny && terminalHasBeenCreated && !terminalAltBufferActive || terminalFocusInAny && terminalProcessSupported && !terminalAltBufferActive",
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus",
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus",
  },
]
